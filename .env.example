# Where the "Login" / "Get started" buttons send people (the product app).
# Local dev points at the running app; production points at app.ioffice.com.
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional: the Loom (or other) product demo embed URL. When set, the hero's
# demo slot renders the video; when empty it shows the animated mockup.
NEXT_PUBLIC_DEMO_EMBED_URL=
